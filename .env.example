# Convex client URL for the deployment this app should read from.
NEXT_PUBLIC_CONVEX_URL=

# Secret bearer token required by POST /api/publish in production.
# Generate a long random value and store the same value in your local CLI config.
POSTPLAN_PUBLISH_TOKEN=

# Clerk authentication.
PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# Defaults to zakethegr8@gmail.com when omitted.
POSTPLAN_ALLOWED_EMAIL=
