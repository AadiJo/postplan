---
import { SignIn, SignOutButton } from "@clerk/astro/components";
import Layout from "../layouts/Layout.astro";
import { getUserPrimaryEmail, isAllowedEmail } from "../lib/auth";
import { getProjects } from "../lib/plans";

export const prerender = false;

const auth = Astro.locals.auth();
const user = auth.isAuthenticated ? await Astro.locals.currentUser() : null;
const userEmail = getUserPrimaryEmail(user);
const isAuthenticated = auth.isAuthenticated;
const isAuthorized = Boolean(isAuthenticated && userEmail && isAllowedEmail(userEmail));
const projects = isAuthorized ? await getProjects() : [];
const planCount = projects.reduce((count, project) => count + project.plans.length, 0);
const clerkAppearance = {
  elements: {
    headerSubtitle: "hidden",
    footer: "hidden",
    footerAction: "hidden",
    footerItem: "hidden",
  },
};
---

<Layout>
  <main class:list={["page", { "auth-page": !isAuthenticated }]}>
    {
      !isAuthenticated ? (
        <SignIn routing="hash" appearance={clerkAppearance} />
      ) : !isAuthorized ? (
        <section class="auth-panel" aria-label="Unauthorized">
          <div class="topbar">
            <p class="brand">// postplan</p>
            <SignOutButton asChild redirectUrl="/">
              <button class="icon-button" type="button" aria-label="Sign out" title="Sign out">
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M10 17v2H5V5h5v2H7v10h3Zm6.6-1.4-1.4-1.4 1.7-1.7H10v-2h6.9l-1.7-1.7 1.4-1.4L20.7 12l-4.1 3.6Z" />
                </svg>
              </button>
            </SignOutButton>
          </div>
          <h1>plans are restricted</h1>
          <p class="intro">
            The signed-in account <code>{userEmail || "unknown"}</code> is not allowed to view
            published plans.
          </p>
        </section>
      ) : (
        <>
          <div class="topbar">
            <p class="brand">// postplan</p>
            <SignOutButton asChild redirectUrl="/">
              <button class="icon-button" type="button" aria-label="Sign out" title="Sign out">
                <svg aria-hidden="true" viewBox="0 0 24 24">
                  <path d="M10 17v2H5V5h5v2H7v10h3Zm6.6-1.4-1.4-1.4 1.7-1.7H10v-2h6.9l-1.7-1.7 1.4-1.4L20.7 12l-4.1 3.6Z" />
                </svg>
              </button>
            </SignOutButton>
          </div>
          <h1>published agent plans</h1>
          <p class="intro">
            Browse project groups, open a plan by its direct identifier, and keep the local source
            of truth in each repository's <code>.plans/</code> directory.
          </p>
          <p class="meta">
            {projects.length} projects / {planCount} plans / routes resolve as <code>/[id]</code>
          </p>
          <div class="toolbar">
            <input
              class="search"
              id="plan-search"
              placeholder="filter projects or plans"
              aria-label="Filter projects or plans"
            />
          </div>
          {projects.length === 0 ? (
            <p class="empty">No published plans match this view.</p>
          ) : (
            <div class="project-list" id="project-list">
              {projects.map((project, index) => (
                <details data-project={project.slug.toLowerCase()} open={index < 3}>
                  <summary>
                    <span class="project-name">{project.displayName ?? project.slug}</span>
                    <span class="project-count">{project.plans.length} plans</span>
                  </summary>
                  <ul class="plan-list">
                    {project.plans.map((plan) => (
                      <li
                        class="plan-row"
                        data-plan={[project.slug, plan.localName, plan.date, plan.publicId]
                          .join(" ")
                          .toLowerCase()}
                      >
                        <span class="plan-date">{plan.date}</span>
                        <a class="plan-name" href={`/${plan.publicId}`}>
                          {plan.localName}
                        </a>
                        <span class="plan-id">{plan.publicId.slice(0, 8)}</span>
                      </li>
                    ))}
                  </ul>
                </details>
              ))}
            </div>
          )}
          <p class="empty is-hidden" id="no-results">No published plans match this view.</p>
          <script>
            const search = document.querySelector<HTMLInputElement>("#plan-search");
            const projects = [
              ...document.querySelectorAll<HTMLDetailsElement>("#project-list details"),
            ];
            const noResults = document.querySelector<HTMLElement>("#no-results");

            search?.addEventListener("input", () => {
              const query = search.value.trim().toLowerCase();
              let visibleProjects = 0;

              for (const project of projects) {
                const rows = [...project.querySelectorAll<HTMLElement>(".plan-row")];
                let visibleRows = 0;

                for (const row of rows) {
                  const matches = !query || row.dataset.plan?.includes(query);
                  row.hidden = !matches;
                  if (matches) visibleRows += 1;
                }

                project.hidden = visibleRows === 0;
                project.open = Boolean(query) || project.open;
                if (visibleRows > 0) visibleProjects += 1;
              }

              noResults?.classList.toggle("is-hidden", visibleProjects !== 0);
            });
          </script>
        </>
      )
    }
  </main>
</Layout>
