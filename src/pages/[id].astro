---
import { addPlainTextAlternate, htmlToPlainText, prefersPlainText } from "../lib/htmlText";
import { getPlanByPublicId } from "../lib/plans";

export const prerender = false;

if (!Astro.params.id) {
  return new Response("Plan not found.", { status: 404 });
}

try {
  const plan = await getPlanByPublicId(Astro.params.id);
  const textUrl = new URL(Astro.url);
  textUrl.searchParams.set("format", "txt");

  if (!plan) {
    return new Response("Plan not found.", { status: 404 });
  }

  if (
    Astro.url.searchParams.get("format") === "txt" ||
    prefersPlainText(Astro.request.headers.get("accept"))
  ) {
    return new Response(`${htmlToPlainText(plan.html)}\n`, {
      headers: {
        "content-type": "text/plain; charset=utf-8",
        "cache-control": "no-store",
        vary: "accept",
      },
    });
  }

  return new Response(addPlainTextAlternate(plan.html, textUrl.href), {
    headers: {
      "content-type": "text/html; charset=utf-8",
      "cache-control": "no-store",
      link: `<${textUrl.href}>; rel="alternate"; type="text/plain"`,
      vary: "accept",
    },
  });
} catch (error) {
  return new Response(error instanceof Error ? error.message : "Plan failed to load.", {
    status: 500,
  });
}
---
